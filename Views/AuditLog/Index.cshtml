@model List<AuditLog>
@{
    ViewData["Title"] = "Audit Log";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Audit Log</h1>
        <p class="text-gray-500 text-sm mt-1">Track all user activities and system events</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50 text-gray-600">
                    <tr>
                        <th class="px-6 py-3 font-medium w-44">Timestamp</th>
                        <th class="px-6 py-3 font-medium">User</th>
                        <th class="px-6 py-3 font-medium">Role</th>
                        <th class="px-6 py-3 font-medium">Action</th>
                        <th class="px-6 py-3 font-medium">Details</th>
                        <th class="px-6 py-3 font-medium">IP Address</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var log in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-3 text-gray-500 whitespace-nowrap">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td class="px-6 py-3 font-medium text-gray-900">@log.Username</td>
                            <td class="px-6 py-3">
                                @if (log.Role == "SuperAdmin")
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-50 text-red-700">SuperAdmin</span>
                                }
                                else if (log.Role == "Admin")
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-50 text-yellow-700">Admin</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">User</span>
                                }
                            </td>
                            <td class="px-6 py-3">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700">@log.Action</span>
                            </td>
                            <td class="px-6 py-3 text-gray-600">@log.Details</td>
                            <td class="px-6 py-3 text-gray-400 text-xs">@(log.IpAddress ?? "-")</td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-400">No audit log entries found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
