@model UpdatePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="max-w-md mx-auto mt-10">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Change Password</h1>
            <p class="text-gray-500 text-sm mt-1">Update your account password</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-4 bg-green-50 border border-green-200 rounded-lg p-4">
                <p class="text-sm text-green-700">@TempData["SuccessMessage"]</p>
            </div>
        }

        <form asp-action="UpdatePassword" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg p-3"></div>

            <div>
                <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="CurrentPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" autocomplete="current-password" />
                <span asp-validation-for="CurrentPassword" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div>
                <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="NewPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div>
                <label asp-for="ConfirmNewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ConfirmNewPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" autocomplete="new-password" />
                <span asp-validation-for="ConfirmNewPassword" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div class="flex items-center space-x-3 pt-2">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg transition-colors focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                    Update Password
                </button>
                <a href="/Dashboard" class="text-gray-600 hover:text-gray-800 font-medium text-sm transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
