@model CreateUserViewModel
@{
    ViewData["Title"] = "Add User";
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
}

<div class="max-w-lg mx-auto mt-10">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Add User</h1>
            <p class="text-gray-500 text-sm mt-1">Create a new user account</p>
        </div>

        <form asp-action="Create" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg p-3"></div>

            <div>
                <label asp-for="Username" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Username" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="Enter username" autocomplete="off" />
                <span asp-validation-for="Username" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="Enter password" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1"></span>
                <p class="text-xs text-gray-400 mt-1">Must be at least 6 characters</p>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ConfirmPassword" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="Confirm password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div>
                <label asp-for="Role" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <select asp-for="Role" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all bg-white">
                    @if (isSuperAdmin)
                    {
                        <option value="Admin">Admin</option>
                    }
                    <option value="User" selected>User</option>
                </select>
                <span asp-validation-for="Role" class="text-xs text-red-500 mt-1"></span>
                @if (!isSuperAdmin)
                {
                    <p class="text-xs text-gray-400 mt-1">Admins can only create regular users</p>
                }
            </div>

            <div class="flex items-center space-x-3 pt-2">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg transition-colors focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                    Create User
                </button>
                <a href="/Users" class="text-gray-600 hover:text-gray-800 font-medium text-sm transition-colors">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
