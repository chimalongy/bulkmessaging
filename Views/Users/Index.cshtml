@model List<User>
@{
    ViewData["Title"] = "Users";
    var isSuperAdmin = (bool)(ViewBag.IsSuperAdmin ?? false);
    var currentUsername = ViewBag.CurrentUsername as string ?? "";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Users</h1>
            <p class="text-gray-500 text-sm mt-1">Manage user accounts</p>
        </div>
        <a href="/Users/Create" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add User
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 bg-green-50 border border-green-200 rounded-lg p-4">
            <p class="text-sm text-green-700">@TempData["SuccessMessage"]</p>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-sm text-red-700">@TempData["ErrorMessage"]</p>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50 text-gray-600">
                    <tr>
                        <th class="px-6 py-3 font-medium">Username</th>
                        <th class="px-6 py-3 font-medium">Role</th>
                        <th class="px-6 py-3 font-medium">Status</th>
                        <th class="px-6 py-3 font-medium">Created</th>
                        <th class="px-6 py-3 font-medium">Last Login</th>
                        <th class="px-6 py-3 font-medium">Created By</th>
                        <th class="px-6 py-3 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900">@user.Username</td>
                            <td class="px-6 py-4">
                                @if (user.Role == "SuperAdmin")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700">SuperAdmin</span>
                                }
                                else if (user.Role == "Admin")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700">Admin</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">User</span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-1.5"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                        <span class="w-1.5 h-1.5 rounded-full bg-gray-400 mr-1.5"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-gray-500">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4 text-gray-500">
                                @(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")
                            </td>
                            <td class="px-6 py-4 text-gray-500">@user.CreatedBy</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end space-x-2">
                                    @if (user.Username != currentUsername && user.Role != "SuperAdmin")
                                    {
                                        <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            @if (user.IsActive)
                                            {
                                                <button type="submit" class="text-xs px-3 py-1.5 rounded-md bg-yellow-50 text-yellow-700 hover:bg-yellow-100 font-medium transition-colors" onclick="return confirm('Deactivate this user?')">Deactivate</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="text-xs px-3 py-1.5 rounded-md bg-green-50 text-green-700 hover:bg-green-100 font-medium transition-colors" onclick="return confirm('Activate this user?')">Activate</button>
                                            }
                                        </form>
                                    }
                                    @if (isSuperAdmin && user.Role != "SuperAdmin")
                                    {
                                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-xs px-3 py-1.5 rounded-md bg-red-50 text-red-700 hover:bg-red-100 font-medium transition-colors" onclick="return confirm('Delete this user permanently?')">Delete</button>
                                        </form>
                                    }
                                    @if (user.Username == currentUsername)
                                    {
                                        <span class="text-xs text-gray-400 italic">You</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-8 text-center text-gray-400">No users found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
