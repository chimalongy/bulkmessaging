@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="max-w-lg mx-auto mt-20 text-center">
    <div class="bg-red-50 border border-red-200 rounded-lg p-8">
        <h1 class="text-4xl font-bold text-red-600 mb-4">Error</h1>
        <p class="text-gray-700 mb-4">An error occurred while processing your request.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-sm text-gray-500">
                <strong>Request ID:</strong> <code class="bg-gray-100 px-2 py-1 rounded">@Model.RequestId</code>
            </p>
        }
        <a href="/" class="inline-block mt-6 bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg transition-colors">
            Go Home
        </a>
    </div>
</div>
